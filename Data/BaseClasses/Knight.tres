[resource]
script = ExtResource("2_yuuka")
class_title = "Knight"
description = "Not a holy crusader. Not of a knightly order. Just someone who learned that a shield, a vow, and a clear head can keep people breathing. Knights specialize in protection and control; holding a line, absorbing pressure, and creating safe space for allies to do their work.
Best for: players who want to tank, peel enemies off teammates, and be the party’s anchor."
allowed_point_targets = null
allowed_equipment_classes = null
